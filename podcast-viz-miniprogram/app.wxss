/* 全局暗金色主题 */
page {
  --bg: #0a0a0f;
  --bg2: #0f0f18;
  --bg3: #13131f;
  --gold: #d4a017;
  --gold-light: #f0c040;
  --amber: #c07830;
  --text: #e8e0d0;
  --text-dim: #8a8070;
  --text-muted: #5a5248;
  --danger: #e74c3c;
  --radius: 16rpx;

  background-color: var(--bg);
  color: var(--text);
  font-family: -apple-system, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用工具类 */
.container {
  padding: 40rpx 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: var(--bg2);
  border-radius: var(--radius);
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.gold-text {
  color: var(--gold);
}

.dim-text {
  color: var(--text-dim);
  font-size: 24rpx;
}
