.header {
  text-align: center;
  padding: 48rpx 0 40rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  margin-bottom: 24rpx;
}

.meta-info {
  margin-top: 8rpx;
}

.podcast-name {
  display: block;
  color: var(--text-dim);
  font-size: 24rpx;
}

.ep-title {
  display: block;
  color: var(--text);
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 8rpx;
}

/* 步骤 */
.steps {
  padding: 20rpx 0;
}

.step {
  display: flex;
  align-items: flex-start;
  padding: 28rpx 32rpx;
  background: var(--bg2);
  border-radius: var(--radius);
  margin-bottom: 16rpx;
  border-left: 6rpx solid var(--text-muted);
  transition: all 0.3s ease;
}

.step.running {
  border-left-color: var(--gold);
  background: var(--bg3);
}

.step.done {
  border-left-color: #2ecc71;
}

.step.error {
  border-left-color: var(--danger);
}

.step-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  width: 48rpx;
  text-align: center;
}

.step-content {
  flex: 1;
}

.step-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.step-detail {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
}

/* 错误 */
.error-box {
  text-align: center;
  padding: 40rpx;
  margin-top: 32rpx;
}

.error-text {
  display: block;
  color: var(--danger);
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.back-btn {
  background: var(--bg2);
  color: var(--gold);
  border: 2rpx solid var(--gold);
  border-radius: var(--radius);
  font-size: 28rpx;
  padding: 16rpx 48rpx;
}

.back-btn::after {
  border: none;
}

/* 提示 */
.tips {
  text-align: center;
  padding: 48rpx 32rpx;
}

.tips text {
  display: block;
  margin-bottom: 12rpx;
}
