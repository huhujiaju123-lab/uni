.page-episode {
  padding-bottom: 120rpx;
}

/* Hero */
.hero {
  position: relative;
  height: 480rpx;
  overflow: hidden;
}

.hero-cover {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(transparent, rgba(10, 10, 15, 0.9));
}

.hero-podcast-name {
  font-size: 24rpx;
  color: var(--gold);
  margin-bottom: 8rpx;
}

.hero-title {
  font-family: var(--font-serif);
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
  line-height: 1.3;
}

.hero-quote {
  font-size: 26rpx;
  color: var(--text-dim);
  margin-top: 16rpx;
  font-style: italic;
}

/* Nav FAB */
.nav-fab {
  position: fixed;
  right: 32rpx;
  bottom: 200rpx;
  width: 80rpx;
  height: 80rpx;
  background: var(--gold);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
}

.nav-fab-icon {
  font-size: 36rpx;
  color: var(--bg);
}

/* Nav Panel */
.nav-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.nav-panel.show {
  visibility: visible;
  opacity: 1;
}

.nav-panel-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.nav-panel-content {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 560rpx;
  background: var(--bg-card);
  padding: 100rpx 32rpx 32rpx;
  overflow-y: auto;
  transform: translateX(100%);
  transition: transform 0.3s ease;
}

.nav-panel.show .nav-panel-content {
  transform: translateX(0);
}

.nav-panel-title {
  font-family: var(--font-serif);
  font-size: 32rpx;
  color: var(--gold);
  margin-bottom: 32rpx;
}

.nav-item {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 12rpx;
  border-bottom: 1rpx solid var(--border);
}

.nav-item.active {
  background: var(--gold-dim);
  border-radius: 8rpx;
}

.nav-time {
  font-size: 24rpx;
  color: var(--text-muted);
  width: 90rpx;
  flex-shrink: 0;
}

.nav-label {
  font-size: 28rpx;
  color: var(--text);
}

/* Content Overview */
.content-overview {
  margin: 24rpx 32rpx;
}

.overview-blocks {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.overview-block {
  padding: 16rpx 20rpx;
  background: var(--bg);
  border-radius: 12rpx;
  border-left: 4rpx solid var(--gold);
}

.overview-block-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 4rpx;
}

.overview-block-desc {
  font-size: 24rpx;
  color: var(--text-dim);
}

/* Sections */
.sections-scroll {
  padding: 0 32rpx;
}

/* Arguments */
.arguments-section {
  margin: 24rpx 32rpx;
}

.argument-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.argument-item:last-child {
  border-bottom: none;
}

.argument-claim {
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.argument-evidence {
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: 1.5;
}

.argument-strength {
  margin-top: 12rpx;
  height: 6rpx;
  background: var(--bg);
  border-radius: 3rpx;
  overflow: hidden;
}

.strength-bar {
  height: 100%;
  background: var(--gold);
  border-radius: 3rpx;
  transition: width 0.6s ease;
}

/* Concepts */
.concepts-section {
  margin: 24rpx 32rpx;
}

.concept-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.concept-item:last-child {
  border-bottom: none;
}

.concept-term {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gold);
  margin-bottom: 4rpx;
}

.concept-definition {
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: 1.5;
}

/* Quotes */
.quotes-section {
  margin: 24rpx 32rpx;
}

/* Reading */
.reading-section {
  margin: 24rpx 32rpx;
}

.reading-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.reading-item:last-child {
  border-bottom: none;
}

.reading-direction {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.reading-resource {
  display: block;
  font-size: 24rpx;
  color: var(--text-dim);
  margin-top: 4rpx;
}

/* Footer */
.footer {
  text-align: center;
  padding: 60rpx 32rpx;
}

.footer-podcast {
  font-family: var(--font-serif);
  font-size: 36rpx;
  color: var(--gold);
  margin-bottom: 12rpx;
}

.footer-powered {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 32rpx;
}

.share-btn {
  background: transparent;
  border: 2rpx solid var(--gold);
  color: var(--gold);
  font-size: 28rpx;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  display: inline-block;
}

.share-btn::after {
  border: none;
}

/* Loading & Error */
.loading-full,
.error-full {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 16rpx;
}
