.poster-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 300;
  display: flex;
  align-items: center;
  justify-content: center;
}

.poster-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
}

.poster-panel {
  position: relative;
  z-index: 1;
  width: 600rpx;
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 32rpx;
}

.poster-preview {
  width: 100%;
  height: 720rpx;
  border-radius: 12rpx;
}

.poster-placeholder {
  width: 100%;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg);
  border-radius: 12rpx;
}

.poster-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.poster-btn {
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: var(--gold);
  color: var(--bg);
  font-weight: 600;
}

.poster-btn.save {
  background: var(--success);
  color: #fff;
}

.poster-btn.cancel {
  background: transparent;
  color: var(--text-dim);
  border: 1rpx solid var(--border);
}
