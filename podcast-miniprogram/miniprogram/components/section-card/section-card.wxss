.section-card {
  background: var(--bg-card);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border);
  overflow: hidden;
}

/* Header */
.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
}

.section-number {
  font-size: 22rpx;
  color: var(--text-muted);
  background: var(--bg);
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.section-title-wrap {
  flex: 1;
  min-width: 0;
}

.section-title {
  font-family: var(--font-serif);
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--text-dim);
  margin-top: 4rpx;
}

.section-arrow {
  font-size: 36rpx;
  color: var(--text-muted);
  transition: transform 0.2s;
  transform: rotate(0deg);
}

.section-arrow.expanded {
  transform: rotate(90deg);
}

/* Body */
.section-body {
  padding: 0 24rpx 24rpx;
}

/* Key Points */
.key-points {
  margin-bottom: 20rpx;
}

.point-group {
  margin-bottom: 16rpx;
}

.group-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--gold);
  margin-bottom: 8rpx;
}

.point-item {
  display: flex;
  gap: 8rpx;
  margin-bottom: 8rpx;
  line-height: 1.6;
}

.point-bullet {
  color: var(--gold);
  flex-shrink: 0;
  margin-top: 2rpx;
}

.point-text {
  font-size: 26rpx;
  color: var(--text);
}

/* Stories */
.stories {
  margin-top: 16rpx;
}

.story-item {
  display: flex;
  gap: 12rpx;
  background: var(--bg);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  border-left: 4rpx solid var(--amber);
}

.story-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.story-text {
  font-size: 26rpx;
  color: var(--text-dim);
  line-height: 1.6;
}
