/* ===== 全局设计系统 ===== */
/* 与 Web 版 :root 变量对应 */

page {
  --bg: #0a0a0f;
  --bg-card: #141419;
  --bg-card-hover: #1a1a22;
  --gold: #d4a017;
  --gold-dim: rgba(212, 160, 23, 0.15);
  --amber: #c07830;
  --text: #e8e0d0;
  --text-dim: #8a8275;
  --text-muted: #555;
  --border: rgba(212, 160, 23, 0.1);
  --danger: #c0392b;
  --success: #27ae60;

  --font-serif: 'Noto Serif SC', 'Source Han Serif SC', serif;
  --font-sans: -apple-system, 'SF Pro Text', 'Helvetica Neue', sans-serif;

  background-color: var(--bg);
  color: var(--text);
  font-family: var(--font-sans);
  font-size: 28rpx;
  line-height: 1.6;
}

/* ===== 通用工具类 ===== */

.container {
  padding: 32rpx;
}

.card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border);
}

.card-title {
  font-family: var(--font-serif);
  font-size: 32rpx;
  font-weight: 600;
  color: var(--gold);
  margin-bottom: 16rpx;
}

.card-subtitle {
  font-size: 24rpx;
  color: var(--text-dim);
  margin-bottom: 24rpx;
}

.text-gold { color: var(--gold); }
.text-dim { color: var(--text-dim); }
.text-muted { color: var(--text-muted); }

.tag {
  display: inline-block;
  background: var(--gold-dim);
  color: var(--gold);
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.btn-primary {
  background: var(--gold);
  color: var(--bg);
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.divider {
  height: 1rpx;
  background: var(--border);
  margin: 32rpx 0;
}

/* ===== 动画 ===== */

.fade-in {
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
